# API Configuration
# ====================

# --- LOCALHOST (desarrollo local) ---
VITE_API_BASE_URL=http://localhost:8080/RipserApp
VITE_API_URL=http://localhost:8080/RipserApp/api

# --- VPS / PRODUCCION (con Nginx proxy reverso) ---
#Nginx redirige /api/* -> http://127.0.0.1:8080/RipserApp/api/*
