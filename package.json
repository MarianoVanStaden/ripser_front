{
  "name": "ripser_frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:pom": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:pom:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:pom:debug": "playwright test --config=e2e/playwright.config.ts --debug",
    "test:all": "vitest run && playwright test",
    "preview": "vite preview",
    "kpis": "node src/scripts/compute-kpis.cjs",
    "kpis:build": "npm run build && node src/scripts/compute-kpis.cjs --with-build"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@mui/icons-material": "^6.5.0",
    "@mui/lab": "^6.0.1-beta.36",
    "@mui/material": "^6.5.0",
    "@mui/system": "^7.3.5",
    "@mui/x-data-grid": "^8.14.0",
    "@mui/x-date-pickers": "^8.6.0",
    "@tanstack/react-query": "^5.96.0",
    "axios": "^1.10.0",
    "dayjs": "^1.11.13",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.65.0",
    "react-mui-sidebar": "^1.6.3",
    "react-router-dom": "^7.6.3",
    "recharts": "^3.6.0",
    "yup": "^1.7.1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.3.1",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "jsdom": "^29.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.34.1",
    "vite": "^7.0.0",
    "vitest": "^4.1.0"
  }
}
