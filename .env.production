# Producción — VPS 76.13.161.228
# =========================================================
# VITE_API_BASE_URL vacío = axios usa URLs relativas (/api/*)
# Nginx hace proxy de /api/* → http://76.13.161.228:8080/RipserApp/api/*
# =========================================================

VITE_API_BASE_URL=
VITE_API_URL=/api
VITE_API_TIMEOUT=10000
