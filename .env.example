# =============================================================
#  ripser_front — Variables de entorno
#  Copiar a .env (desarrollo) o .env.production (producción)
# =============================================================

# URL base del backend (sin trailing slash).
# - Desarrollo local: apunta directo al backend
# - Producción con Nginx proxy: dejar VACÍO (nginx maneja el proxy)
# - Producción sin Nginx proxy: URL completa del VPS
#
# Ejemplos:
#   VITE_API_BASE_URL=http://localhost:8080/RipserApp   ← dev local
#   VITE_API_BASE_URL=                                  ← prod con nginx proxy
#   VITE_API_BASE_URL=http://76.13.161.228:8080/RipserApp ← prod directo
VITE_API_BASE_URL=http://localhost:8080/RipserApp

# Prefijo de todas las rutas de la API REST.
# - Desarrollo local: URL completa (el proxy de Vite agrega /RipserApp)
# - Producción con Nginx proxy: ruta relativa /api (nginx reescribe a /RipserApp/api)
# - Producción directo: URL completa con /RipserApp/api
#
# Ejemplos:
#   VITE_API_URL=http://localhost:8080/RipserApp/api    ← dev local
#   VITE_API_URL=/api                                   ← prod con nginx proxy
VITE_API_URL=http://localhost:8080/RipserApp/api

# Timeout de peticiones HTTP en milisegundos (default: 10000)
VITE_API_TIMEOUT=10000

# =============================================================
#  Sentry — error tracking (OPS-002)
# =============================================================
# DSN del proyecto Sentry. Si está vacío, el SDK no envía nada.
# Crear proyecto en https://sentry.io/ → Settings → Client Keys (DSN).
VITE_SENTRY_DSN=
# Entorno reportado a Sentry. Si vacío, usa import.meta.env.MODE.
VITE_SENTRY_ENVIRONMENT=
# Release tag — idealmente seteado en CI a partir del SHA del commit
# (ej: VITE_SENTRY_RELEASE=ripser-front@$GITHUB_SHA).
VITE_SENTRY_RELEASE=
# Performance tracing 0..1. Default 0 (apagado). 0.1 captura 10%.
VITE_SENTRY_TRACES_SAMPLE_RATE=0
# Permitir envío desde dev (truthy = sí). Por defecto, dev no envía.
VITE_SENTRY_SEND_IN_DEV=
